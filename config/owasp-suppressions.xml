  <!-- ================================================================
       CATEGORY C: Log4j-api — API bridge only, Logback is the backend
       ================================================================
       Spring Boot's default logging backend is Logback. log4j-api.jar
       provides the Log4j 2 API abstraction (a routing layer) but
       log4j-core, which contains the exploitable code paths, is NOT on
       the classpath. Vulnerabilities in the API jar itself have no
       code path to the exploitable features.
       Re-evaluate if log4j-core is ever added as a direct dependency.
  -->
  <suppress>
    <notes>log4j-api CVE — no log4j-core on classpath; Spring Boot uses Logback as implementation.</notes>
    <gav regex="true">^org\.apache\.logging\.log4j:log4j-api:.*$</gav>
    <cve>CVE-2025-68161</cve>
  </suppress>
  <suppress>
    <notes>log4j-api CVE — no log4j-core on classpath; Spring Boot uses Logback as implementation.</notes>
    <gav regex="true">^org\.apache\.logging\.log4j:log4j-api:.*$</gav>
    <cve>CVE-2026-34477</cve>
  </suppress>
  <suppress>
    <notes>log4j-api CVE — no log4j-core on classpath; Spring Boot uses Logback as implementation.</notes>
    <gav regex="true">^org\.apache\.logging\.log4j:log4j-api:.*$</gav>
    <cve>CVE-2026-34478</cve>
  </suppress>
  <suppress>
    <notes>log4j-api CVE — no log4j-core on classpath; Spring Boot uses Logback as implementation.</notes>
    <gav regex="true">^org\.apache\.logging\.log4j:log4j-api:.*$</gav>
