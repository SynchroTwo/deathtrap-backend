  <!-- ================================================================
       CATEGORY G: commons-fileupload2 M2 — pre-release transitive
       ================================================================
       commons-fileupload2-2.0.0-M2 is a Milestone release pulled in as
       a transitive dependency of Tomcat 10.1.x via the Spring Boot BOM.
       It is used for multipart parsing in the embedded servlet container
       which, as noted above, is never started in Lambda. Re-evaluate
       when Tomcat upgrades to a GA release of commons-fileupload2.
  -->
  <suppress>
    <notes>commons-fileupload2 M2 is a Tomcat transitive; embedded server not started in Lambda. Re-evaluate on Tomcat upgrade to GA fileupload2.</notes>
    <gav regex="true">^org\.apache\.commons:commons-fileupload2.*$</gav>
    <cve>CVE-2025-48976</cve>
  </suppress>

  <!-- ================================================================
       CATEGORY H: postgresql — CPE false positive after 42.7.4 upgrade
       ================================================================
       CVE-2026-42198 was the reason postgresql was upgraded to 42.7.4.
       The NVD CPE match may still flag 42.7.4 due to broad version-range
       patterns in the NVD entry. The fix version is 42.7.4+.
  -->
  <suppress>
    <notes>CVE-2026-42198 fix is postgresql 42.7.4; we are on 42.7.4. NVD CPE match is a false positive.</notes>
    <gav regex="true">^org\.postgresql:postgresql:.*$</gav>
    <cve>CVE-2026-42198</cve>
  </suppress>

