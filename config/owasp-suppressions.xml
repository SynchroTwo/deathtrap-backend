<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check suppressions for DeathTrap backend.
  Each entry documents: (1) why the CVE is not exploitable or fixable, and
  (2) when to re-evaluate. Only suppress after triage.

  Reference: https://jeremylong.github.io/DependencyCheck/general/suppression.html
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!-- ================================================================
       CATEGORY A: Build-tool dependencies (never deployed to Lambda)
       ================================================================ -->

  <!--
    commons-beanutils and guava are transitive deps of Checkstyle (build-time only).
    Re-evaluate when Checkstyle drops or upgrades these artifacts.
  -->
  <suppress>
    <notes>commons-beanutils is a transitive dep of Checkstyle build tool — never deployed to Lambda.</notes>
    <gav regex="true">^commons-beanutils:commons-beanutils:.*$</gav>
    <cve>CVE-2025-48734</cve>
  </suppress>

  <!-- ================================================================
       CATEGORY B: Tomcat — embedded server never started in Lambda
       ================================================================
       DeathTrap services run as AWS Lambda functions. The Lambda runtime
       invokes the handler method directly; tomcat-embed-* jars are on
       the classpath (from spring-boot-starter-web) but the embedded
       HTTP server is never bound to a port. All HTTP-listener attack
       vectors are therefore not reachable.
       Re-evaluate if any service is migrated to run as a long-lived
       container/ECS task.
  -->
  <suppress>
    <notes>Tomcat HTTP-server CVE — embedded server never started in AWS Lambda deployment.</notes>
    <gav regex="true">^org\.apache\.tomcat\.embed:.*$</gav>
    <cve>CVE-2025-61795</cve>
  </suppress>
